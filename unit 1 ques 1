# Create list
my_list = [10, 20, 30, 40]

# Access elements
print("First element:", my_list[0])

# Add elements
my_list.append(50)
print("After append:", my_list)

# Remove elements
my_list.remove(20)
print("After remove:", my_list)

# Sort list
my_list.sort()
print("Sorted list:", my_list)

# Reverse list
my_list.reverse()
print("Reversed list:", my_list)
